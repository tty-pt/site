{
  "compilerOptions": { "jsx": "react-jsx", "jsxImportSource": "preact" },
  "imports": {
    "npm:playwright": "npm:playwright",
    "$fresh/": "https://deno.land/x/fresh@1.7.3/",
    "@std/path": "jsr:@std/path@^1.1.4",
    "preact": "https://esm.sh/preact@10.22.0",
    "preact/": "https://esm.sh/preact@10.22.0/",
    "@preact/signals": "https://esm.sh/*@preact/signals@1.2.2",
    "@preact/signals-core": "https://esm.sh/*@preact/signals-core@1.5.1",
    "preact-render-to-string": "https://esm.sh/*preact-render-to-string@6.2.2",
    "@/": "./mods/",
    "#/": "./"
  },
  "tasks": {
    "setup-routes": "deno run --allow-read --allow-write scripts/setup-routes.ts",
    "start": "deno run --allow-read --allow-write scripts/setup-routes.ts && deno run -A --watch=static/,routes/ dev.ts",
    "build": "deno run --allow-read --allow-write scripts/setup-routes.ts && deno run -A dev.ts build",
    "serve": "deno run --allow-read --allow-write scripts/setup-routes.ts && deno run -A main.ts",
    "build:css": "npm run build:css",
    "e2e": "deno test --allow-all tests/e2e/"
  },
  "nodeModulesDir": "auto",
  "lint": { "rules": { "tags": ["fresh", "recommended"] } },
  "exclude": ["**/_fresh/*", "**/node_modules/*"]
}
